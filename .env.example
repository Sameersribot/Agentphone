# AgentLine Environment Variables
# Copy this to .env and fill in your values

# Supabase (Auth + Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Database (get from Supabase Dashboard → Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Plivo — for Indian numbers (sign up at https://console.plivo.com)
PLIVO_AUTH_ID=your_auth_id
PLIVO_AUTH_TOKEN=your_auth_token
# SignalWire — for US numbers (sign up at https://signalwire.com)
SIGNALWIRE_PROJECT_ID=your_project_id
SIGNALWIRE_TOKEN=your_api_token
SIGNALWIRE_SPACE_URL=your-space.signalwire.com

# Voice Pipeline
DEEPGRAM_API_KEY=xxx
CARTESIA_API_KEY=xxx
OPENAI_API_KEY=xxx

# App
SECRET_KEY=xxx
BASE_URL=https://api.agentline.io
WEBHOOK_SECRET_SALT=xxx
